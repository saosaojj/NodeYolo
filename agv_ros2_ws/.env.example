# =====================================================
# AGV ROS2 Docker 环境配置模板
# =====================================================
# 复制此文件为 .env 并根据实际情况修改

# ===================================================
# ROS2 配置
# ===================================================
ROS_DOMAIN_ID=30
RMW_IMPLEMENTATION=rmw_cyclonedds_cpp

# ===================================================
# AGV Web 服务配置
# ===================================================
AGV_WEB_HOST=0.0.0.0
AGV_WEB_PORT=8080
AGV_WEB_JWT_SECRET=change_this_secret_in_production

# ===================================================
# 功能开关
# ===================================================
ENABLE_VISION=false
ENABLE_SIMULATION=true

# ===================================================
# 摄像头配置
# ===================================================
CAMERA_DEVICE=0
CAMERA_USE_RTSP=false
CAMERA_FPS=30
CAMERA_WIDTH=640
CAMERA_HEIGHT=480

# ===================================================
# PLC 配置
# ===================================================
PLC_IP=127.0.0.1
PLC_PORT=502
PLC_SLAVE_ID=1

# ===================================================
# 数据库配置
# ===================================================
DB_PATH=/root/.agv_web_config/agv_data.db

# ===================================================
# 日志配置
# ===================================================
LOG_LEVEL=INFO
LOG_MAX_SIZE=50m
LOG_MAX_FILES=3

# ===================================================
# 开发配置
# ===================================================
DEBUG=false
PYTHONUNBUFFERED=1

# ===================================================
# GPU 支持（仅视觉服务）
# ===================================================
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility
